# ================ MaxMind 账户配置 ================
# 在 https://www.maxmind.com/en/geolite2/signup 注册并获取
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# ================ 数据库配置 ================
# 数据库下载路径
GEOIP_DOWNLOAD_PATH=./geoip_databases

# 要下载的数据库类型（逗号分隔）
GEOIP_EDITIONS=GeoLite2-ASN,GeoLite2-City

# ================ 数据库文件路径 ================
# 更新后需要指向最新版本的 .mmdb 文件
# 格式：GEOIP_DOWNLOAD_PATH/数据库名称/文件名.mmdb
ASN_DB_PATH=./geoip_databases/GeoLite2-ASN/GeoLite2-ASN.mmdb
CITY_DB_PATH=./geoip_databases/GeoLite2-City/GeoLite2-City.mmdb

# ================ 定时更新配置 ================
# Cron 表达式（秒 分 时 日 月 星期）
# 示例：
#   每天凌晨 3 点：0 0 3 * * *
#   每周日凌晨 2 点：0 0 2 * * 0
#   每月 1 号凌晨 1 点：0 0 1 1 * *
#   每 6 小时：0 0 */6 * * *
#   每 30 分钟：0 */30 * * * *
GEOIP_UPDATE_CRON=0 0 3 * * *

# ================ 服务器配置 ================
SERVER_PORT=3000
